# Homebrew packages for Linux (Ubuntu, Bluefin, etc.)
# These are user-level CLI tools installed via Linuxbrew.
# System packages are handled separately (apt.list or rpm-ostree.list).

brew "zsh-autosuggestions"
brew "eza"
brew "zoxide"
brew "fzf"
brew "gh"
brew "git-lfs"

# Neovim and dependencies
brew "neovim"
brew "tree-sitter"

# LSP servers
brew "lua-language-server"
brew "bash-language-server"
brew "pyright"
brew "ruff"
brew "gopls"
brew "rust-analyzer"
