# Use ctrl-j for the prefix
unbind C-b
set -g prefix C-j
bind C-j send-prefix

# List of plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-battery'
set -g @plugin 'samoshkin/tmux-plugin-sysstat'

# Reload config
bind r source-file ~/.tmux.conf

# Split panes using | and -
bind | split-window -h
bind - split-window -v

# Switch panes using Alt-hjkl (vi home row)
bind -n M-h select-pane -L
bind -n M-l select-pane -R
bind -n M-k select-pane -U
bind -n M-j select-pane -D

# Next/prev window
bind -n M-n next-window
bind -n M-p previous-window

# True color support — sets inner $TERM and tells tmux to pass RGB through
# from whatever terminal is on the outside (Ghostty, etc.)
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"

# Remove delay after Escape (default 500ms breaks vim/neovim)
set -g escape-time 0

# Forward focus events to programs running inside panes (needed for neovim autoread etc.)
set -g focus-events on

# Increase scrollback buffer (default is 2000)
set -g history-limit 50000

# Mouse support
set -g mouse on

# Propagate display env vars to tmux sessions on client attach, so that
# copy commands (wl-copy etc.) can find the right display socket
set -g update-environment "WAYLAND_DISPLAY DISPLAY XDG_RUNTIME_DIR"

# Vi keybindings in copy mode
setw -g mode-keys vi

# Reduce scroll speed for touchpad (default is 5 lines per wheel event)
bind -T copy-mode-vi WheelUpPane   select-pane \; send-keys -X -N 1 scroll-up
bind -T copy-mode-vi WheelDownPane select-pane \; send-keys -X -N 1 scroll-down

# Copy to system clipboard and PRIMARY selection (for middle-click)
unbind -T copy-mode-vi Enter
{{ if eq .chezmoi.os "darwin" -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{ else if eq .chezmoi.osRelease.id "fedora" -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "tee >(wl-copy --primary) | wl-copy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "tee >(wl-copy --primary) | wl-copy"
{{ else -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "sh -c 'if [ -n \"$WAYLAND_DISPLAY\" ]; then tee >(wl-copy --primary) | wl-copy; else tee >(xclip -in -selection primary) | xclip -in -selection clipboard; fi'"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "sh -c 'if [ -n \"$WAYLAND_DISPLAY\" ]; then tee >(wl-copy --primary) | wl-copy; else tee >(xclip -in -selection primary) | xclip -in -selection clipboard; fi'"
{{ end -}}

#################
# Visual changes
#################

color_orange="colour166"
color_purple="colour134"
color_green="colour076"
color_blue="colour39"
color_yellow="colour220"
color_red="colour160"
color_black="colour232"
color_white="white"

# Panes
set -g pane-border-style 'fg=colour19 bg=colour0'
set -g pane-active-border-style 'bg=colour0 fg=colour9'

# Widgets for the status bar
wg_session="#[fg=$color_blue] #S #[default]"
wg_battery="#{battery_status_fg} #{battery_icon} #{battery_percentage}"
wg_date="#[fg=$color_green]%h %d %H:%M#[default]"

# Status bar
set -g status-position bottom
set -g status-justify left
set -g status-style "fg=colour245,bg=$color_black"
set -g status-left "$wg_session"
set -g status-right "#{sysstat_cpu} | #{sysstat_loadavg} | $wg_date $wg_battery"
set -g status-right-length 100

setw -g window-status-current-style 'fg=colour1 bg=colour19 bold'
setw -g window-status-current-format ' #I#[fg=colour249]:#[fg=colour255]#W#[fg=colour249]#F '

setw -g window-status-style 'fg=colour9 bg=colour18'
setw -g window-status-format ' #I#[fg=colour237]:#[fg=colour250]#W#[fg=colour244]#F '

setw -g window-status-bell-style 'fg=colour255 bg=colour1 bold'

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'
