# Use ctrl-j for the prefix
unbind C-b
set -g prefix C-j
bind C-j send-prefix

# List of plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-cpu'
set -g @plugin 'tmux-plugins/tmux-battery'
set -g @plugin 'catppuccin/tmux'

# Reload config
bind r source-file ~/.tmux.conf

# Split panes using | and - , inheriting the current pane's working directory
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# Switch panes using Alt-hjkl (vi home row)
bind -n M-h select-pane -L
bind -n M-l select-pane -R
bind -n M-k select-pane -U
bind -n M-j select-pane -D

# Next/prev window
bind -n M-n next-window
bind -n M-p previous-window

# True color support — sets inner $TERM and tells tmux to pass RGB through
# from whatever terminal is on the outside (Ghostty, etc.)
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"

# Remove delay after Escape (default 500ms breaks vim/neovim)
set -g escape-time 0

# Forward focus events to programs running inside panes (needed for neovim autoread etc.)
set -g focus-events on

# Increase scrollback buffer (default is 2000)
set -g history-limit 50000

# Mouse support
set -g mouse on

# Propagate display env vars to tmux sessions on client attach, so that
# copy commands (wl-copy etc.) can find the right display socket
set -g update-environment "WAYLAND_DISPLAY DISPLAY XDG_RUNTIME_DIR"

# Vi keybindings in copy mode
setw -g mode-keys vi

# Reduce scroll speed for touchpad (default is 5 lines per wheel event)
bind -T copy-mode-vi WheelUpPane   select-pane \; send-keys -X -N 1 scroll-up
bind -T copy-mode-vi WheelDownPane select-pane \; send-keys -X -N 1 scroll-down

# Copy to system clipboard and PRIMARY selection (for middle-click)
unbind -T copy-mode-vi Enter
{{ if eq .chezmoi.os "darwin" -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{ else if eq .chezmoi.osRelease.id "fedora" -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "tee >(wl-copy --primary) | wl-copy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "tee >(wl-copy --primary) | wl-copy"
{{ else -}}
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "sh -c 'if [ -n \"$WAYLAND_DISPLAY\" ]; then tee >(wl-copy --primary) | wl-copy; else tee >(xclip -in -selection primary) | xclip -in -selection clipboard; fi'"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "sh -c 'if [ -n \"$WAYLAND_DISPLAY\" ]; then tee >(wl-copy --primary) | wl-copy; else tee >(xclip -in -selection primary) | xclip -in -selection clipboard; fi'"
{{ end -}}

# Catppuccin settings — must be set before loading the plugin
set -g @catppuccin_flavor "mocha"
set -g @catppuccin_window_status_style "rounded"
set -g @catppuccin_window_text "#W"
set -g @catppuccin_window_current_text "#W"
set -g @catppuccin_date_time_text "%h %d %H:%M"

# Initialize TMUX plugin manager
# NOTE: keep this before the catppuccin run below — TPM installs plugins,
# then catppuccin runs a second time so our overrides are applied last.
run '~/.tmux/plugins/tpm/tpm'

# Re-run catppuccin after TPM so the following overrides are not wiped by TPM's plugin pass
run ~/.tmux/plugins/tmux/catppuccin.tmux

# tmux-battery and tmux-cpu interpolate #{...} placeholders in status-right/left, which
# are never reached inside catppuccin's module variables. Call the scripts directly instead.
set -g @catppuccin_battery_text "#(~/.tmux/plugins/tmux-battery/scripts/battery_percentage.sh)"
set -g @catppuccin_status_battery "#[fg=#{@thm_lavender}]#[fg=#{@thm_crust},bg=#{@thm_lavender}]#(~/.tmux/plugins/tmux-battery/scripts/battery_icon.sh) #[fg=#{@thm_text},bg=#{@thm_surface0}]#{E:@catppuccin_battery_text}#[fg=#{@thm_surface0}] "
set -g @catppuccin_cpu_text "#(~/.tmux/plugins/tmux-cpu/scripts/cpu_percentage.sh)"
set -g @catppuccin_status_cpu "#[fg=#{@thm_yellow}]#[fg=#{@thm_crust},bg=#{@thm_yellow}] #[fg=#{@thm_text},bg=#{@thm_surface0}]#{E:@catppuccin_cpu_text}#[fg=#{@thm_surface0}] "

# Date/time: carry the sapphire accent through to the text so icon and time match
set -g @catppuccin_status_date_time "#[fg=#{@thm_sapphire}]#[fg=#{@thm_crust},bg=#{@thm_sapphire}]󰃰 #[fg=#{@thm_sapphire},bg=#{@thm_surface0}]#{E:@catppuccin_date_time_text}#[fg=#{@thm_surface0}] "

# Window status: use basic style to avoid thin rounded glyphs clashing with
# the bolder powerline arrows on the status modules
set -g @catppuccin_window_status_style "basic"

# Status bar — configured last so nothing overwrites these settings
set -g status-position bottom
set -g status-left-length 100
set -g status-right-length 100

# Session indicator — solid powerline arrow () right edge, prefix turns it red
set -g status-left "#[fg=#{?client_prefix,#{@thm_red},#{@thm_green}},bg=#{@thm_mantle}]#[fg=#{@thm_crust},bg=#{?client_prefix,#{@thm_red},#{@thm_green}},bold] #S #[fg=#{?client_prefix,#{@thm_red},#{@thm_green}},bg=#{@thm_mantle}]"

# Window list — solid powerline arrows () and () matching the right-side modules
# Clear tmux's default window-status-style (colour18/colour19) so it doesn't bleed into the wings/body
set -g window-status-style "bg=#{@thm_mantle},fg=#{@thm_overlay_2}"
set -g window-status-current-style "bg=#{@thm_mantle},fg=#{@thm_mauve}"
set -g window-status-format "#[fg=#{@thm_surface0},bg=#{@thm_mantle}]#[fg=#{@thm_overlay_2},bg=#{@thm_surface0}] #I #W #[fg=#{@thm_surface0},bg=#{@thm_mantle}]"
set -g window-status-current-format "#[fg=#{@thm_mauve},bg=#{@thm_mantle}]#[fg=#{@thm_crust},bg=#{@thm_mauve},bold] #I #W #[fg=#{@thm_mauve},bg=#{@thm_mantle}]"

set -g status-right "#{E:@catppuccin_status_cpu}"
set -ag status-right "#{E:@catppuccin_status_date_time}"
set -ag status-right "#{E:@catppuccin_status_battery}"
